{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/styles.css", "destination": "/public/styles.css" },
    { "source": "/viewer.js", "destination": "/public/viewer.js" },
    { "source": "/signature_pad.min.js", "destination": "/public/signature_pad.min.js" },
    { "source": "/(.*)", "destination": "/api/index.ts" }
  ]
}
