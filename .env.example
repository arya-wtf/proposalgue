# Copy to .env.local for development. Set these in Vercel dashboard for production.

# Public URL of your deployed app (no trailing slash)
# Dev: http://localhost:3000
# Prod: https://your-project.vercel.app (update when you connect a custom domain)
PUBLIC_BASE_URL=http://localhost:3000

# Random secret used to generate share tokens — NEVER rotate after links are sent
# Generate: openssl rand -hex 32
SHARE_SECRET=dev-secret-change-in-prod

# Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=re_...

# Email address that receives "signed" notifications — must be verified in Resend
AUTHOR_EMAIL=hello@elux.space

# Admin area password — set a strong value in prod
ADMIN_TOKEN=change-me

# Optional: path to system Chrome for local PDF generation
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
